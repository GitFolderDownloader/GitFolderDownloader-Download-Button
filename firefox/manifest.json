{
  "manifest_version": 3,
  "name": "GitFolderDownloader Download Button",
  "version": "1.0.0",
  "description": "Adds a Git Folder Downloader Api Download button to GitHub repo and directory menus.",
  "homepage_url": "https://github.com/GitFolderDownloader",

  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "gfd-down-button@gitfolderdownloader.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
