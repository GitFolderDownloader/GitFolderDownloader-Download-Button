{
  "manifest_version": 3,
  "name": "GitFolderDownloader Download Button",
  "version": "1.0.0",
  "description": "Adds a Git Folder Downloader Api Download button to GitHub repo and directory menus.",
  "author": "Pro Bandey",
  "homepage_url": "https://GitFolderDownloader.github.io",

  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png",
      "128": "icons/128.png"
    }
  },

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  }
}
